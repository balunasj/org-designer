# Data import configuration
# See docs/import-schema.md for the all_users.json schema.

# Path to all_users.json (default: data/all_users.json)
# ALL_USERS_PATH=data/all_users.json

# Path to org YAML directory containing org.yaml, team_groups/, teams/
# Leave unset to import people only (no team assignments).
# ORG_FLEET_PATH=/path/to/org/yaml/directory
